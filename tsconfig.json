{
  "compilerOptions": {
    "experimentalDecorators": true,
    "module": "esnext",
    "target": "es2021",
    "lib": ["esnext"],
    "moduleResolution": "node",
    "sourceMap": false,
    "declaration": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "importHelpers": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "paths": {
      "@scalar/core/libs/html-rendering": ["./node_modules/@scalar/core/dist/libs/html-rendering"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
